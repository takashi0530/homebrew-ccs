#!/bin/bash
# ccs — Claude Code セッションを全プロジェクト横断で検索・再開する
#
# 使い方:
#   ccs                  全セッションを新しい順に一覧 → カーソルで選んで Enter で再開
#   ccs <キーワード>     タイトル等でfzf初期絞り込み
#   ccs -g <キーワード>  会話の本文まで全文検索（固定文字列。このときだけ全ファイルをgrep）
#   ccs -l [kw]          一覧表示のみ（再開しない）
#   ccs --days N         直近N日のセッションだけ表示
#   ccs --cwd            今いるディレクトリ(配下/親)のセッションだけ表示
#   ccs backup           全セッションをバックアップ（自動削除対策）
#   ccs -m <mode>        権限モードを指定して再開 (normal / auto / skip)
#   ccs -h               ヘルプ
#
# 再開時の権限モード（fzf画面でも選択可）:
#   Enter  = 通常（settings.json の設定どおり）
#   Ctrl-A = auto（編集を自動許可 = --permission-mode acceptEdits）
#   Ctrl-X = dangerously-skip（--dangerously-skip-permissions）
#
# 設定: ~/.config/ccs/config （KEY=VALUE形式・1行1設定。環境変数で一時上書き可）
#   CCS_MAX=100          表示件数の上限
#   CCS_MIN_KB=0         このサイズ(KB)未満のセッションを除外
#   CCS_MIN_MSGS=0       ユーザー発言数がこの数未満のセッションを除外
#   CCS_EXCLUDE=''       タイトルがこの正規表現に一致するセッションを除外
#   CCS_BACKUP_DIR=~/.claude-session-backups
#
# 表示: ★シアン=名前付き(/rename済み) / グレー=無名(最初のプロンプトを表示)
# 注意: ~/.claude/projects/ の内部仕様(非公式)に依存。Claude Code更新で壊れる可能性あり。

set -uo pipefail

VERSION="1.0.1"

PROJ_DIR="$HOME/.claude/projects"
HIST="$HOME/.claude/history.jsonl"
CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/ccs/config"

is_num() { case "$1" in ''|*[!0-9]*) return 1 ;; *) return 0 ;; esac; }

# ── OS差分の吸収 (macOS=BSD / Linux=GNU) ──
OS=$(uname -s)
file_meta() {  # 出力: "サイズ(bytes) エポック秒"
  if [ "$OS" = Darwin ]; then stat -f '%z %m' "$1"; else stat -c '%s %Y' "$1"; fi
}
fmt_epoch() {  # エポック秒 → "YYYY-MM-DD HH:MM"
  if [ "$OS" = Darwin ]; then date -r "$1" '+%Y-%m-%d %H:%M'; else date -d "@$1" '+%Y-%m-%d %H:%M'; fi
}
sed_i() {
  if [ "$OS" = Darwin ]; then sed -i '' "$@"; else sed -i "$@"; fi
}

# タブ・制御文字・不正なUTF-8バイトを除去
# （表示崩れ・フィールド破壊・端末エスケープ注入・awkのマルチバイトエラー対策）
sanitize() { tr '\t' ' ' | tr -d '\000-\010\013\014\016-\037\177' | iconv -f UTF-8 -t UTF-8 -c; }

# ── 設定読み込み（優先度: 環境変数 > configファイル > デフォルト）──
# configはsourceせず KEY=VALUE のみ解釈する（任意コード実行を防ぐ）
_e_MAX="${CCS_MAX:-}"; _e_MIN_KB="${CCS_MIN_KB:-}"; _e_MIN_MSGS="${CCS_MIN_MSGS:-}"
_e_EXCLUDE="${CCS_EXCLUDE:-}"; _e_BACKUP_DIR="${CCS_BACKUP_DIR:-}"
cfg_MAX=''; cfg_MIN_KB=''; cfg_MIN_MSGS=''; cfg_EXCLUDE=''; cfg_BACKUP_DIR=''
if [ -f "$CONFIG" ]; then
  while IFS='=' read -r k v; do
    case "$k" in \#*|'') continue ;; esac
    v=${v%\"}; v=${v#\"}; v=${v%\'}; v=${v#\'}
    v=${v//\$HOME/$HOME}; v=${v/#\~/$HOME}
    case "$k" in
      CCS_MAX)        cfg_MAX=$v ;;
      CCS_MIN_KB)     cfg_MIN_KB=$v ;;
      CCS_MIN_MSGS)   cfg_MIN_MSGS=$v ;;
      CCS_EXCLUDE)    cfg_EXCLUDE=$v ;;
      CCS_BACKUP_DIR) cfg_BACKUP_DIR=$v ;;
    esac
  done < "$CONFIG"
fi
CCS_MAX=${_e_MAX:-${cfg_MAX:-100}}
CCS_MIN_KB=${_e_MIN_KB:-${cfg_MIN_KB:-0}}
CCS_MIN_MSGS=${_e_MIN_MSGS:-${cfg_MIN_MSGS:-0}}
CCS_EXCLUDE=${_e_EXCLUDE:-${cfg_EXCLUDE:-}}
CCS_BACKUP_DIR=${_e_BACKUP_DIR:-${cfg_BACKUP_DIR:-$HOME/.claude-session-backups}}

for pair in "CCS_MAX=$CCS_MAX" "CCS_MIN_KB=$CCS_MIN_KB" "CCS_MIN_MSGS=$CCS_MIN_MSGS"; do
  is_num "${pair#*=}" || { echo "${pair%%=*} が数値ではありません: ${pair#*=}" >&2; exit 1; }
done

print_help() {
  local B=$'\033[1m' C=$'\033[1;36m' Y=$'\033[1;33m' D=$'\033[2m' R=$'\033[0m'
  cat <<EOF
${B}ccs${R} — Claude Code セッションを全プロジェクト横断で検索・再開する

${Y}基本${R}
  ${C}ccs${R}                  一覧を開く → ↑↓で選択、文字入力で絞り込み
  ${C}ccs 動画${R}             最初からキーワードで絞り込んで開く
  ${C}ccs -g BGM${R}           ${B}会話の中身まで全文検索${R}（タイトルに無い話題を探すとき）

${Y}選択画面のキー${R}
  ${C}Enter${R}   通常モードで再開        ${C}Ctrl-A${R}  auto(編集自動許可)で再開
  ${C}Esc${R}     キャンセル              ${C}Ctrl-X${R}  dangerously-skip で再開

${Y}絞り込みオプション${R}
  ${C}--days N${R}             直近N日のセッションのみ
  ${C}--cwd${R}                今いるディレクトリに関係するもののみ
  ${C}-l${R}                   一覧を表示するだけ（開かない）

${Y}その他${R}
  ${C}-m normal|auto|skip${R}  権限モードを先に指定して開く
  ${C}ccs backup${R}           全セッションを退避（自動削除対策）
  ${C}ccs config${R}           設定の表示 / ${C}ccs config max 200${R} で変更 / ${C}ccs config edit${R} で編集
  ${C}ccs help${R} / ${C}-h${R}       このヘルプ

${Y}使用例${R}
  ${D}\$${R} ccs -g "Basic認証"        ${D}# あの話どこでしたっけ？を本文から探す${R}
  ${D}\$${R} ccs --days 7 --cwd        ${D}# 今週このプロジェクトでやった作業${R}
  ${D}\$${R} ccs -m skip 動画          ${D}# 「動画」を dangerously-skip で開く${R}

${Y}設定${R} ${D}(~/.config/ccs/config)${R}
  CCS_MAX=100        一覧の最大件数           CCS_MIN_KB=3      小さすぎる無名セッションを除外
  CCS_MIN_MSGS=2     発言が少ない無名を除外   CCS_EXCLUDE=''    タイトル正規表現で除外
  CCS_BACKUP_DIR=~/.claude-session-backups
  ${D}※ フィルタは無名セッションのみ対象。/rename で名前を付けたセッションは常に表示${R}
  ${D}※ 環境変数で一時上書き可: CCS_MAX=200 ccs${R}

${Y}ヒント${R}
  残したいセッションには Claude Code 内で ${C}/rename 名前${R} を。★付きで強調表示され、
  件数上限やフィルタに関係なく必ず一覧に出ます。
EOF
}

# ── config サブコマンド ──
config_show() {
  echo "現在の設定 (config: $CONFIG)"
  echo "  CCS_MAX        = $CCS_MAX	(一覧の最大件数)"
  echo "  CCS_MIN_KB     = $CCS_MIN_KB	(このKB未満の無名セッションを除外)"
  echo "  CCS_MIN_MSGS   = $CCS_MIN_MSGS	(発言数がこれ未満の無名セッションを除外)"
  echo "  CCS_EXCLUDE    = ${CCS_EXCLUDE:-(なし)}	(タイトル除外の正規表現)"
  echo "  CCS_BACKUP_DIR = $CCS_BACKUP_DIR"
  echo ""
  echo "変更: ccs config (対話式) / ccs config max 200 (一発) / ccs config edit (エディタ)"
}

config_set() {
  local key=$1 val=$2
  # キー名を正規化 (max / MAX / CCS_MAX / min-kb などを受け付ける)
  key=$(printf '%s' "$key" | tr 'a-z-' 'A-Z_')
  case "$key" in CCS_*) : ;; *) key="CCS_$key" ;; esac
  case "$key" in
    CCS_MAX|CCS_MIN_KB|CCS_MIN_MSGS)
      is_num "$val" || { echo "$key は数値で指定してください: $val" >&2; exit 1; } ;;
    CCS_EXCLUDE|CCS_BACKUP_DIR) : ;;
    *) echo "不明なキー: $1 (max / min-kb / min-msgs / exclude / backup-dir)" >&2; exit 1 ;;
  esac
  mkdir -p "$(dirname "$CONFIG")"
  [ -f "$CONFIG" ] || config_write_default
  if grep -q "^${key}=" "$CONFIG"; then
    sed_i "s|^${key}=.*|${key}=${val}|" "$CONFIG"
  else
    printf '%s=%s\n' "$key" "$val" >> "$CONFIG"
  fi
  echo "設定しました: ${key}=${val}"
}

config_cmd() {
  case "${1:-}" in
    '')
      # 対話式: fzf で項目を選んで値を入力するだけ
      if [ -t 0 ] && command -v fzf >/dev/null 2>&1; then
        local sel key cur val
        sel=$(printf '%s\n' \
          "max	${CCS_MAX}	一覧の最大件数" \
          "min-kb	${CCS_MIN_KB}	このKB未満の無名セッションを除外" \
          "min-msgs	${CCS_MIN_MSGS}	発言数がこれ未満の無名セッションを除外" \
          "exclude	${CCS_EXCLUDE:-(なし)}	タイトル除外の正規表現" \
          "backup-dir	${CCS_BACKUP_DIR}	backupの保存先" \
          | column -t -s$'\t' \
          | fzf --header='変更する設定を↑↓で選んで Enter / Esc=表示のみで終了' \
                --height=~40% --layout=reverse --info=hidden) || { config_show; exit 0; }
        key=$(printf '%s' "$sel" | awk '{print $1}')
        cur=$(printf '%s' "$sel" | awk '{print $2}')
        printf '%s の新しい値 (現在: %s、Enterでキャンセル): ' "$key" "$cur"
        read -r val
        [ -z "$val" ] && { echo "変更しませんでした。"; exit 0; }
        config_set "$key" "$val"
      else
        config_show
      fi
      ;;
    show) config_show ;;
    edit)
      mkdir -p "$(dirname "$CONFIG")"
      [ -f "$CONFIG" ] || config_write_default
      exec "${EDITOR:-vi}" "$CONFIG"
      ;;
    *)
      local k=$1 v=${2-}
      [ $# -lt 2 ] && { echo "値を指定してください: ccs config $k <値>" >&2; exit 1; }
      config_set "$k" "$v"
      ;;
  esac
  exit 0
}

config_write_default() {
  cat > "$CONFIG" <<'EOF'
# ccs 設定ファイル (KEY=VALUE形式・1行1設定)
# 表示件数の上限（名前付きセッションは上限に関係なく常に表示）
CCS_MAX=100
# このサイズ(KB)未満の無名セッションを除外
CCS_MIN_KB=3
# ユーザー発言数がこの数未満の無名セッションを除外
CCS_MIN_MSGS=2
# タイトルがこの正規表現に一致するセッションを除外（例: ^(あ|a|test)$）
CCS_EXCLUDE=
# backup の保存先
CCS_BACKUP_DIR=$HOME/.claude-session-backups
EOF
}

# ── 引数パース ──
list_only=false; grep_kw=''; days=0; cwd_only=false; kw=''; mode=''
while [ $# -gt 0 ]; do
  case "$1" in
    -h|--help|help) print_help; exit 0 ;;
    -v|--version) echo "ccs $VERSION"; exit 0 ;;
    config|-config|--config) shift; config_cmd "$@" ;;
    -l|--list) list_only=true ;;
    -g|--grep) shift; grep_kw="${1:?-g にはキーワードが必要です}" ;;
    --days)    shift; days="${1:?--days には日数が必要です}"
               is_num "$days" || { echo "--days は数値で指定してください: $days" >&2; exit 1; } ;;
    --cwd)     cwd_only=true ;;
    -m|--mode) shift; mode="${1:?-m には normal/auto/skip を指定}" ;;
    backup)    do_backup=1 ;;
    -*)        echo "不明なオプション: $1 (ccs -h でヘルプ)" >&2; exit 1 ;;
    *)         kw="$1" ;;
  esac
  shift
done

# モード名 → claude のフラグ
mode_flags() {
  case "$1" in
    auto)   echo "--permission-mode acceptEdits" ;;
    skip)   echo "--dangerously-skip-permissions" ;;
    normal|'') echo "" ;;
    *) echo "不明なモード: $1 (normal/auto/skip)" >&2; exit 1 ;;
  esac
}
[ -n "$mode" ] && mode_flags "$mode" >/dev/null  # 不正値なら即エラー

# ── backup サブコマンド ──
if [ "${do_backup:-}" = 1 ]; then
  mkdir -p "$CCS_BACKUP_DIR"
  before=$(find "$CCS_BACKUP_DIR" -name '*.jsonl' 2>/dev/null | wc -l | tr -d ' ')
  rsync -a "$PROJ_DIR"/ "$CCS_BACKUP_DIR"/
  after=$(find "$CCS_BACKUP_DIR" -name '*.jsonl' 2>/dev/null | wc -l | tr -d ' ')
  total=$(du -sh "$CCS_BACKUP_DIR" | cut -f1)
  echo "バックアップ完了: $CCS_BACKUP_DIR"
  echo "  セッション数: $after 件（今回新規: $((after - before)) 件） / 合計サイズ: $total"
  echo "  ※ Claude Code の自動削除(cleanupPeriodDays, 既定30日)後もここに残ります。"
  echo "  ※ 戻すときは該当の .jsonl を ~/.claude/projects/ の同名フォルダにコピーしてください。"
  exit 0
fi

# ── 全文検索モード: 対象ファイルを本文grep(固定文字列)で絞り込む ──
target_files=("$PROJ_DIR"/*/*.jsonl)
if [ -n "$grep_kw" ]; then
  matched=$(grep -liF -- "$grep_kw" "$PROJ_DIR"/*/*.jsonl 2>/dev/null || true)
  [ -z "$matched" ] && { echo "本文に「$grep_kw」を含むセッションはありません。" >&2; exit 1; }
  target_files=()
  while IFS= read -r _f; do target_files+=("$_f"); done <<< "$matched"
fi

now=$(date +%s)

# 無名セッションのラベル用に history.jsonl を一度だけパースしておく
# (@tsv がタブ・改行を \t \n にエスケープするのでフィールド破壊も防げる)
hist_titles=''
if [ -f "$HIST" ]; then
  hist_titles=$(jq -r 'select(.display and .sessionId) | [.sessionId, .display] | @tsv' "$HIST" 2>/dev/null \
    | awk -F'\t' '$2 !~ /^\// && !seen[$1]++ {print}' || true)
fi

# ── セッション情報の収集 ──
# フィールド: epoch \t 日時 \t 名前付き \t タイトル \t cwd \t サイズ \t 発言数 \t id \t ファイル
rows=""
for f in ${target_files[@]+"${target_files[@]}"}; do
  [ -e "$f" ] || continue
  id=$(basename "$f" .jsonl)
  read -r size epoch <<< "$(file_meta "$f")"
  mtime=$(fmt_epoch "$epoch")
  kb=$(( size / 1024 ))
  if [ "$days" -gt 0 ]; then
    [ "$epoch" -lt $(( now - days * 86400 )) ] && continue
  fi

  cwd=$(grep -m1 -o '"cwd":"[^"]*"' "$f" | cut -d'"' -f4)
  [ -z "$cwd" ] && cwd="(不明)"
  if $cwd_only; then
    case "$cwd" in "$PWD"|"$PWD"/*) : ;; *) case "$PWD" in "$cwd"|"$cwd"/*) : ;; *) continue ;; esac ;; esac
  fi

  # ユーザー発言数（メタ行・ツール実行結果を除く）
  msgs=$(grep '"type":"user"' "$f" | grep -v '"isMeta":true' | grep -vc '"type":"tool_result"' || true)

  named=1
  title=$(grep -o '"customTitle":"[^"]*"' "$f" | tail -1 | cut -d'"' -f4 | sanitize)
  if [ -z "$title" ]; then
    named=0
    if [ -n "$hist_titles" ]; then
      # cut -c はバイト単位でマルチバイト文字を壊すため、切ってから sanitize で修復
      title=$(printf '%s\n' "$hist_titles" | grep -m1 "^$id"$'\t' | cut -f2- \
        | sed 's/\\[tnr]/ /g' | cut -c1-180 | sanitize)
    fi
  fi
  [ -z "$title" ] && title="(無題)"

  # サイズ・発言数フィルタは無名セッションのみに適用（/rename済みは常に表示）
  if [ "$named" = 0 ]; then
    [ "$kb" -lt "$CCS_MIN_KB" ] && continue
    [ "$msgs" -lt "$CCS_MIN_MSGS" ] && continue
  fi
  if [ -n "$CCS_EXCLUDE" ] && printf '%s' "$title" | grep -qiE -- "$CCS_EXCLUDE"; then
    continue
  fi

  rows+="${epoch}"$'\t'"${mtime}"$'\t'"${named}"$'\t'"${title}"$'\t'"${cwd/#$HOME/~}"$'\t'"${kb}KB"$'\t'"${msgs}msg"$'\t'"${id}"$'\t'"${f}"$'\n'
done

total=$(printf '%s' "$rows" | wc -l | tr -d ' ')
# 新しい順に並べる。件数上限(CCS_MAX)は無名セッションのみに適用し、
# 名前付き(/rename済み)は件数に関係なく必ず含める
# 以降のフィールド: 日時(1) 名前付き(2) タイトル(3) cwd(4) サイズ(5) 発言数(6) id(7) ファイル(8)
sorted=$(printf '%s' "$rows" | sort -t$'\t' -k1,1 -rn \
  | awk -F'\t' -v max="$CCS_MAX" '$3 == 1 {print; next} cnt < max {print; cnt++}' \
  | cut -f2-)
shown=$(printf '%s\n' "$sorted" | grep -c . || true)
trunc_note=''
[ "$total" -gt "$shown" ] && trunc_note="※ ${shown}/${total} 件を表示中 (無名の古い分を省略。上限は CCS_MAX で変更可)"

if [ -z "$sorted" ]; then
  echo "条件に合うセッションが見つかりません。" >&2
  exit 1
fi

# fzf 用の表示行を組み立てる（パスを右端に揃える）。
# 出力: 表示行 \t 元の8フィールド（cwd/id等の取り出しは cut -f2- で元に戻す）
# macOS標準awkはマルチバイト非対応のため LC_ALL=C でバイト単位に処理し、
# UTF-8の先頭バイトから表示幅(日本語=2, ASCII=1)を概算する
format_fzf() {
  LC_ALL=C awk -F'\t' -v width="$1" '
  BEGIN {
    for (i = 128; i < 256; i++) {
      b = sprintf("%c", i)
      if (i >= 224)      W[b] = 2   # 3-4バイトUTF-8の先頭 (日本語・絵文字)
      else if (i >= 194) W[b] = 1   # 2バイトUTF-8の先頭
      else               W[b] = 0   # 継続バイト
    }
  }
  function dw(s,   i,c,w) {
    w = 0
    for (i = 1; i <= length(s); i++) { c = substr(s,i,1); w += (c in W) ? W[c] : 1 }
    return w
  }
  function trunc(s, maxw,   out,i,c,cw,w) {
    if (dw(s) <= maxw) return s
    out = ""; w = 0
    for (i = 1; i <= length(s); i++) {
      c = substr(s,i,1); cw = (c in W) ? W[c] : 1
      # 文字の先頭バイトで幅超過が確定したらそこで打ち切る(継続バイトは幅0で通す)
      if (cw > 0 && w + cw > maxw - 2) return out "…"
      w += cw; out = out c
    }
    return out
  }
  {
    mtime=$1; named=$2; title=$3; cwd=$4; kb=$5; msgs=$6
    star = (named == 1) ? "★ " : ""
    meta = " (" msgs "/" kb ")"
    fixed = dw(mtime) + 2 + dw(star) + dw(meta)
    avail = width - fixed - dw(cwd) - 1
    if (avail < 10) avail = 10
    t = trunc(title, avail)
    pad = width - fixed - dw(t) - dw(cwd)
    if (pad < 1) pad = 1
    sp = sprintf("%" pad "s", "")
    if (named == 1)
      disp = mtime "  \033[1;36m★ " t "\033[0m\033[2m" meta sp cwd "\033[0m"
    else
      disp = mtime "  \033[2m" t meta sp cwd "\033[0m"
    print disp "\t" $0
  }'
}

print_list() {
  local i=0
  while IFS=$'\t' read -r mtime named title cwd kb msgs id file; do
    i=$((i+1))
    if [ "$named" = "1" ]; then
      printf '%2d) %s  \033[1;36m★ %-24s\033[0m %s \033[2m(%s/%s)\033[0m\n' \
        "$i" "$mtime" "$title" "$cwd" "$msgs" "$kb"
    else
      printf '%2d) %s  \033[2m%-26s\033[0m %s \033[2m(%s/%s)\033[0m\n' \
        "$i" "$mtime" "$title" "$cwd" "$msgs" "$kb"
    fi
  done
}

# キーワード絞り込み（-l / fzfなし用。表示列のみを対象にする）
filter_visible() {
  awk -F'\t' -v kw="$1" 'BEGIN{IGNORECASE=1} index(tolower($1 FS $3 FS $4 FS $5 FS $6), tolower(kw)) > 0'
}

if $list_only; then
  filtered=$sorted
  if [ -n "$kw" ]; then
    filtered=$(printf '%s\n' "$sorted" | filter_visible "$kw" || true)
    [ -z "$filtered" ] && { echo "該当するセッションが見つかりません。" >&2; exit 1; }
  fi
  printf '%s\n' "$filtered" | print_list
  [ -n "$trunc_note" ] && echo "$trunc_note"
  exit 0
fi

[ -t 0 ] || { printf '%s\n' "$sorted"; exit 0; }

resume_session() {
  local line=$1 m=${2:-}
  local cwd id flags
  cwd=$(printf '%s' "$line" | cut -f4)
  id=$(printf '%s' "$line" | cut -f7)
  cwd="${cwd/#\~/$HOME}"
  case "$id" in
    -*|''|*[!0-9a-fA-F-]*) echo "不正なセッションID: $id" >&2; exit 1 ;;
  esac
  if [ ! -d "$cwd" ]; then
    echo "セッションの作業ディレクトリが存在しません: $cwd" >&2
    echo "(ディレクトリを復元するか、手動で claude --resume $id を実行してください)" >&2
    exit 1
  fi
  flags=$(mode_flags "$m")
  echo "→ cd $cwd && claude --resume $id ${flags:-(通常モード)}"
  # shellcheck disable=SC2086
  cd "$cwd" && exec claude --resume "$id" $flags
}

# プレビュー: 全文検索時はヒット箇所、通常時は直近のユーザー発言を本文から表示
if [ -n "$grep_kw" ]; then
  # 固定文字列キーワードを grep(BRE) 用にエスケープしてプレビューで文脈表示
  CCS_Q_RE=''
  _q=$grep_kw
  while [ -n "$_q" ]; do
    _c=${_q:0:1}; _q=${_q:1}
    case "$_c" in [\\.\*\[\]^\$/]) CCS_Q_RE+="\\$_c" ;; *) CCS_Q_RE+=$_c ;; esac
  done
  export CCS_Q_RE
  preview='echo "ID: {8}  DIR: {5}"; echo "── ヒット箇所 ──"; grep -o -i ".\{0,60\}$CCS_Q_RE.\{0,60\}" {9} | tr -d '\''\000-\010\013\014\016-\037\177'\'' | head -12'
  header="本文検索「$grep_kw」/ Enter=通常 / C-a=auto / C-x=dangerous-skip / Esc=中止 (★=名前付き)"
else
  preview='echo "ID: {8}  DIR: {5}"; echo "── 直近のユーザー発言 ──"; tail -n 500 {9} | jq -r '\''select(.type=="user" and .isMeta!=true) | .message.content | if type=="string" then . else ([.[] | select(.type=="text") | .text] | join(" ")) end'\'' 2>/dev/null | tr -d '\''\000-\010\013\014\016-\037\177'\'' | grep -v "^[[:space:]]*$" | cut -c1-200 | iconv -f UTF-8 -t UTF-8 -c | tail -12'
  header='↑↓選択+絞り込み / Enter=通常で再開 / C-a=auto / C-x=dangerous-skip / Esc=中止 (★=名前付き)'
fi
[ -n "$trunc_note" ] && header="$header  $trunc_note"

if command -v fzf >/dev/null 2>&1; then
  # 表示行は1列に整形済み(パス右寄せ)。元フィールドは2列目以降に温存
  list_width=$(( $(tput cols 2>/dev/null || echo 120) - 4 ))
  out=$(printf '%s\n' "$sorted" | format_fzf "$list_width" | fzf \
    --ansi \
    --delimiter=$'\t' --with-nth=1 \
    --query="$kw" \
    --expect=ctrl-a,ctrl-x \
    --height=~60% --layout=reverse --info=inline \
    --header="$header" \
    --preview="$preview" \
    --preview-window=down,35%,wrap)
  rc=$?
  case "$rc" in
    0) ;;
    1|130) exit 0 ;;  # マッチなし / Esc キャンセル
    *) echo "fzf がエラー終了しました (exit $rc)。fzf 0.34 以上が必要です。" >&2; exit 1 ;;
  esac
  key=$(printf '%s\n' "$out" | sed -n 1p)
  line=$(printf '%s\n' "$out" | sed -n 2p | cut -f2-)
  case "$key" in
    ctrl-a) mode='auto' ;;
    ctrl-x) mode='skip' ;;
  esac
  [ -n "$line" ] && resume_session "$line" "$mode"
  exit 0
else
  filtered=$sorted
  [ -n "$kw" ] && filtered=$(printf '%s\n' "$sorted" | filter_visible "$kw" || true)
  [ -z "$filtered" ] && { echo "該当するセッションが見つかりません。" >&2; exit 1; }
  printf '%s\n' "$filtered" | print_list
  [ -n "$trunc_note" ] && echo "$trunc_note"
  printf '\n再開するセッション番号 (Enterでキャンセル): '
  read -r num
  [ -z "$num" ] && exit 0
  case "$num" in (*[!0-9]*) echo "番号を入力してください" >&2; exit 1;; esac
  line=$(printf '%s\n' "$filtered" | sed -n "${num}p")
  [ -z "$line" ] && { echo "その番号はありません" >&2; exit 1; }
  if [ -z "$mode" ]; then
    printf '権限モード [Enter]=通常 / a=auto / x=dangerously-skip: '
    read -r m
    case "$m" in a) mode='auto' ;; x) mode='skip' ;; esac
  fi
  resume_session "$line" "$mode"
fi
